#!/usr/bin/env bash
set -euo pipefail

record_dir="$HOME/videos"
pid_file="${XDG_RUNTIME_DIR:-/tmp}/ffrecord.pid"

mkdir -p "$record_dir"

notify() {
    command -v notify-send >/dev/null 2>&1 || return 0
    notify-send "$1" "$2"
}

start_recording() {
    local output
    output="${record_dir}/video-$(date '+%Y-%m-%d_%H_%M_%S').mp4"

    nohup ffmpeg \
        -s 1920x1080 \
        -f x11grab \
        -i :0.0+1920,0 \
        -f alsa \
        -i default \
        -c:v libx264 \
        -qp 0 \
        -pix_fmt yuv420p \
        -c:a aac \
        -b:a 192k \
        "$output" \
        >/dev/null 2>&1 < /dev/null &

    echo "$!" > "$pid_file"
    notify "Screen recording started" "$output"
    printf 'started recording: %s\n' "$output"
}

stop_recording() {
    local pid
    pid="$(cat "$pid_file")"

    if kill -0 "$pid" 2>/dev/null; then
        kill -INT "$pid"
        rm -f "$pid_file"
        notify "Screen recording stopped" ""
        printf 'stopped recording\n'
    else
        rm -f "$pid_file"
        printf 'stale pid file removed\n'
    fi
}

if [[ -f "$pid_file" ]]; then
    stop_recording
else
    start_recording
fi
