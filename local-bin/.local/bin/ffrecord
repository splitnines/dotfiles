#!/usr/bin/env bash
set -euo pipefail

record_dir="$HOME/videos"
pid_file="${XDG_RUNTIME_DIR:-/tmp}/ffrecord.pid"

mkdir -p "$record_dir"

notify() {
    command -v notify-send >/dev/null 2>&1 || return 0
    notify-send "$1" "$2"
}

extract_geometry() {
    line="$(
    	xrandr --listmonitors |
    	awk '
    	    NR == 1 {
    	    	count = $2
    	    	next
    	    }
    	    count >= 2 && $1 ~ /^1:/ { print; exit }
    	    count < 2  && $1 ~ /^0:/ { print; exit }
    	'
    )"
    
    if [[ -z "${line}" ]]; then
    	printf 'failed to determine monitor geometry\n' >&2
    	exit 1
    fi
    
    geometry="$(awk '{ print $3 }' <<<"$line")"
    
    if [[ ! $geometry =~ ^([0-9]+)/[0-9]+x([0-9]+)/[0-9]+\+([0-9]+)\+([0-9]+)$ ]]; then
    	printf 'failed to parse geometry: %s\n' "$geometry" >&2
    	exit 1
    fi
    
    width="${BASH_REMATCH[1]}"
    height="${BASH_REMATCH[2]}"
    x="${BASH_REMATCH[3]}"
    y="${BASH_REMATCH[4]}"

}

start_recording() {
    local output
    output="${record_dir}/video-$(date '+%Y-%m-%d_%H_%M_%S').mp4"
    extract_geometry

    audio_filter="highpass=f=80,afftdn,"
    audio_filter+="agate=threshold=0.02:ratio=8:attack=20:release=250,"
    audio_filter+="acompressor=threshold=-18dB:ratio=3:attack=5:release=80,"
    audio_filter+="volume=3.5,alimiter=limit=0.85"

    nohup ffmpeg \
        -s "${width}"x"${height}" \
	-framerate 30 \
        -f x11grab \
        -i :0.0+"${x}",0 \
        -f alsa \
        -i default \
        -filter:a ${audio_filter} \
        -c:v libx264 \
        -qp 0 \
        -pix_fmt yuv420p \
        -c:a aac \
        -b:a 192k \
        "$output" \
        >/dev/null 2>&1 < /dev/null &

    echo "$!" > "$pid_file"
    notify "Screen recording started" "$output"
    printf 'started recording: %s\n' "$output"
}

stop_recording() {
    local pid
    pid="$(cat "$pid_file")"

    if kill -0 "$pid" 2>/dev/null; then
        kill -INT "$pid"
        rm -f "$pid_file"
        notify "Screen recording stopped" ""
        printf 'stopped recording\n'
    else
        rm -f "$pid_file"
        printf 'stale pid file removed\n'
    fi
}

if [[ -f "$pid_file" ]]; then
    stop_recording
else
    start_recording
fi
