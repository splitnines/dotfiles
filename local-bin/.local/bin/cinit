#!/usr/bin/env bash

if [[ "$#" -lt 1 ]]; then
    echo -e "error: project name not specified\n"
    echo -e "\tusage: cinit <project name>\n"
    exit 1
fi

PROJECT_NAME="$1"

makefile() {
    if [[ ! -f "$PROJECT_NAME/Makefile" ]]; then
        {
            printf 'CC = gcc\n'
            printf 'CFLAGS = -Wall -Wextra\n'
            printf 'LDLIBS = \n'
            printf '\n'
            printf 'PROG = %s\n' "$PROJECT_NAME"
            printf '\n'
            printf 'SRCDIR = src\n'
            printf 'BINDIR = build\n'
            printf '\n'
            printf 'SRC = $(SRCDIR)/main.c\n'
            printf 'BIN = $(BINDIR)/$(PROG)\n'
            printf 'INSTALLDIR = /usr/local/bin'
            printf '\n'
            printf '\n'
            printf 'default: $(BIN)\n'
            printf '\n'
            printf '$(BIN):\n'
            printf '\t$(CC) $(CFLAGS) -o $(BIN) $(SRC) $(LDLIBS)\n'
            printf '\n'
            printf 'clean:\n'
            printf '\trm -rf $(BIN)\n'
            printf '\n'
            printf 'install: $(BIN)\n'
            printf '\tinstall -d $(DESTDIR)$(INSTALLDIR)\n'
            printf '\tinstall -m 755 $(BIN) $(DESTDIR)$(INSTALLDIR)/$(PROG)'
        } > "$PROJECT_NAME/Makefile"
    fi
}

main_c() {
    if [[ ! -f "$PROJECT_NAME/src/main.c" ]]; then
        {
            printf '#include <stdio.h>\n'
            printf '\n'
            printf 'int main() {\n'
            printf '    printf("Hello, fuckers!");\n'
            printf '\n'
            printf '    return 0;\n'
            printf '}\n'
        } > "$PROJECT_NAME/src/main.c"
    fi
}

dir_structure() {
    mkdir -p "$PROJECT_NAME"/{src,build}
}

create_git() {
    touch "$PROJECT_NAME/.gitignore"
    printf 'build/\n' > "$PROJECT_NAME/.gitignore"
    git -C "$PROJECT_NAME" init
}

if [[ ! -d "$PROJECT_NAME" ]]; then
    printf '\033[32mCreating\033[0m C project "%s"\n' "$PROJECT_NAME"

    dir_structure
    create_git
    main_c
    makefile
else
    echo -e "project name \"$PROJECT_NAME\" already exists"
fi
