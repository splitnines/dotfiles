#!/usr/bin/env bash

dep_check() {
    local cmd
    for cmd in "$@"; do
        command -v "$cmd" >/dev/null 2>&1 || {
            echo "Error: required command not found: $cmd"
            exit 1
        }
    done
}

usage() {
    text="Random Password Generator"
    cols=60
    printf "\n%*s\n\n" $(((${#text} + cols) / 2)) "$text"
    echo -e "Usage: $(basename "$0") [options]\n"
    echo -e "Options:"
    echo -e "--------"
    echo -e "  -l [n]:  length of password to generate (default: 16)"
    echo -e "  -n [n]:  number of passwords to generate (default: 12)"
    echo -e "  -s:      no symbols"
    echo -e "  -0:      no numbers"
    echo -e "  -u:      no uppercase"
    echo -e "  -y:      copies a single password to the clipboard"
    exit 1
}

NUM=12
LEN=16
INCLUDE_SYMBOLS=1
INCLUDE_UPPER=1
INCLUDE_NUMBERS=1
COPY=0

SYMBOLS="!@#$%^&*()_+="
UPPER="A-Z"
NUMBERS="0-9"

while getopts :su0hyn:l: OPTIONS; do
    case $OPTIONS in
    n) NUM=$OPTARG ;;
    l) LEN=$OPTARG ;;
    s) INCLUDE_SYMBOLS=0 ;;
    u) INCLUDE_UPPER=0 ;;
    0) INCLUDE_NUMBERS=0 ;;
    y) COPY=1 ;;
    h) usage ;;
    \?) usage ;;
    :) usage ;;
    *) usage ;;
    esac
done
shift $((OPTIND - 1))
if [[ "$#" -gt 0 ]]; then
    usage
fi

dep_check tr column

CHARS="a-z"

if [[ $INCLUDE_SYMBOLS == 1 ]]; then
    CHARS+=$SYMBOLS
fi

if [[ $INCLUDE_UPPER == 1 ]]; then
    CHARS+=$UPPER
fi

if [[ $INCLUDE_NUMBERS == 1 ]]; then
    CHARS+=$NUMBERS
fi

check_string() {
    local string="$1"

    if [[ $INCLUDE_NUMBERS == 1 && "$string" != *[0-9]* ]]; then
        return 1
    fi

    if [[ $INCLUDE_UPPER == 1 && "$string" != *[A-Z]* ]]; then
        return 1
    fi

    if [[ $INCLUDE_SYMBOLS == 1 && "$string" != *[!@#\$%^\&\*\(\)_+]* ]]; then
        return 1
    fi

    return 0
}

if [[ $COPY == 1 ]]; then
    dep_check xclip
    password="$(tr -dc "$CHARS" </dev/urandom | head -c "$LEN" || true)"
    while ! check_string "$password"; do
        password="$(tr -dc "$CHARS" </dev/urandom | head -c "$LEN" || true)"
    done
    printf "%s" "$password" | xclip -selection clipboard -in
    exit 0
fi

for ((n = 1; n <= NUM; n++)); do
    tr -dc "$CHARS" </dev/urandom | head -c "$LEN" || true
    echo
done | column -c "$(tput cols)"
