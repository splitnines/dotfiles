#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $(basename "$0") <input.md> [output.pdf]" >&2
  exit 1
}

[[ $# -ge 1 && $# -le 2 ]] || usage

in="$1"
out="${2:-}"

[[ -f "$in" ]] || { echo "Error: file not found: $in" >&2; exit 1; }

indir="$(cd "$(dirname "$in")" && pwd)"
infile="$(basename "$in")"

if [[ -n "$out" ]]; then
  if [[ "$out" = */* ]]; then
    outdir="$(cd "$(dirname "$out")" && pwd)"
    outfile="$(basename "$out")"
    outpath="$outdir/$outfile"
  else
    outpath="$PWD/$out"
  fi
else
  outfile="${infile%.md}.pdf"
  outpath="$indir/$outfile"
fi

tmp_header="$(mktemp)"
trap 'rm -f "$tmp_header"' EXIT

cat > "$tmp_header" <<'LATEX'
\usepackage{xurl}
\usepackage{fvextra}
\usepackage{xcolor}
\usepackage{graphicx}
\usepackage{tikz}
\usepackage{everypage}
\usepackage{enumitem}

% Better Pandoc task-list checkboxes
\newcommand{\mdUncheckedBox}{%
  \tikz[baseline=-0.15em]{
    \draw[line width=0.45pt, rounded corners=0.5pt]
      (0,0) rectangle (0.9em,0.9em);
  }%
}

\newcommand{\mdCheckedBox}{%
  \tikz[baseline=-0.15em]{
    \draw[line width=0.45pt, rounded corners=0.5pt]
      (0,0) rectangle (0.9em,0.9em);
    \draw[line width=0.75pt]
      (0.18em,0.45em) -- (0.38em,0.22em) -- (0.72em,0.72em);
  }%
}

\AtBeginDocument{%
  \renewcommand{\square}{\mathord{\vcenter{\hbox{\mdUncheckedBox}}}}%
  \renewcommand{\boxtimes}{\mathord{\vcenter{\hbox{\mdCheckedBox}}}}%
}

% Better Markdown list bullets
\newcommand{\mdBulletOne}{%
  \tikz[baseline=-0.55ex]\fill (0,0) circle (0.28em);%
}

\newcommand{\mdBulletTwo}{%
  \tikz[baseline=-0.55ex]\draw[line width=0.45pt] (0,0) circle (0.28em);%
}

\newcommand{\mdBulletThree}{%
  \tikz[baseline=-0.35ex]{
    \draw[line width=0.65pt, rounded corners=0.2pt]
      (0,0) -- (0.55em,0);
  }%
}

\setlist[itemize,1]{label=\mdBulletOne}
\setlist[itemize,2]{label=\mdBulletTwo}
\setlist[itemize,3]{label=\mdBulletThree}


\AddEverypageHook{
  \begin{tikzpicture}[remember picture,overlay]
    \draw[line width=1.5pt]
      ([xshift=0.5in,yshift=-0.5in]current page.north west)
      rectangle
      ([xshift=-0.5in,yshift=0.5in]current page.south east);
  \end{tikzpicture}
}

\setlength{\emergencystretch}{3em}
\DefineVerbatimEnvironment{Highlighting}{Verbatim}{
  breaklines,
  breakanywhere,
  breaksymbolleft={},
  breaksymbolright={},
  commandchars=\\\{\}
}
\RecustomVerbatimEnvironment{Verbatim}{Verbatim}{
  breaklines,
  breakanywhere,
  breaksymbolleft={},
  breaksymbolright={}
}
LATEX

(
  cd "$indir"
  pandoc "$infile" \
    -o "$outpath" \
    --from=markdown+raw_tex \
    --pdf-engine=xelatex \
    -V geometry:margin=1in \
    -V mainfont="DejaVu Serif" \
    -V sansfont="DejaVu Sans" \
    -V monofont="JetBrainsMono Nerd Font Mono" \
    -H "$tmp_header"
)

echo "Created: $outpath"
