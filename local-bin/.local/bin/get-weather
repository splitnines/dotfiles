#!/usr/bin/env bash
set -euo pipefail

url_local='https://radar.weather.gov/ridge/standard/KDAX_loop.gif'
url_national='https://radar.weather.gov/ridge/standard/CONUS-LARGE_loop.gif'
# url='https://s.w-x.co/staticmaps/wu/wu/radsum1200_cur/usbfl/animate.png'
# url='https://cdn.star.nesdis.noaa.gov/GOES19/ABI/CONUS/GEOCOLOR/GOES19-CONUS-GEOCOLOR-625x375.gif'

url="$url_local"

case "${1-}" in
	n)
		url="$url_national"
		;;
	"")
		;;
	*)
		printf 'get-weather: unknown option: %s\n' "${1-}" >&2
		notify-send -t 5000 -u critical "get-weather: unknown option ${1-}"
		exit 1
		;;
esac

curl -fsSL "$url" 2>/dev/null | mpv --loop-file=inf - >/dev/null 2>&1 &
