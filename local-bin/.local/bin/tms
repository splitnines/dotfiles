#!/usr/bin/env bash

SESSION_MAIN="Main"
SESSION_PI="Pi"

if ! tmux has-session -t "$SESSION_MAIN" 2>/dev/null; then
    systemd-run --user --scope --collect --unit=tmux-keep-${USER} \
        "$(command -v tmux)" new-session -d -s Main -n dotfiles 2>/dev/null
    tmux send-keys -t "$SESSION_MAIN":dotfiles 'cd ~/dotfiles/ && clear' C-m
fi

if ! tmux has-session -t "$SESSION_PI" 2>/dev/null; then
    tmux new-session -d -s "$SESSION_PI" -n Pi 2>/dev/null
    tmux send-keys -t "$SESSION_PI":Pi 'pi' C-m 2>/dev/null
fi

if tmux has-session -t "$SESSION_MAIN" 2>/dev/null; then
    tmux attach-session -t "$SESSION_MAIN" 2>/dev/null
fi
