#!/usr/bin/env bash

SESSION_MAIN="Main"
SESSION_PI="Pi"

tmux has-session -t "$SESSION_MAIN" 2>/dev/null
if [ "$?" -eq 1 ]; then
    systemd-run --user --scope --unit=tmux-keep \
        "$(command -v tmux)" new-session -d -s Main -n dotfiles 2>/dev/null
    tmux send-keys -t "$SESSION_MAIN":dotfiles 'cd ~/dotfiles/' C-m 2>/dev/null
fi

tmux has-session -t "$SESSION_PI" 2>/dev/null
if [ "$?" -eq 1 ]; then
    tmux new-session -d -s "$SESSION_PI" -n Pi 2>/dev/null
    tmux send-keys -t "$SESSION_PI":Pi 'pi' C-m 2>/dev/null
fi

tmux has-session -t "$SESSION_MAIN" 2>/dev/null
if [ "$?" -eq 0 ]; then
    tmux attach-session -t "$SESSION_MAIN" 2>/dev/null
fi
