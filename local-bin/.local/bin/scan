#!/usr/bin/env bash
# scan-yara-system: system-wide YARA hunt wrapper for Linux persistence threats.

set -uo pipefail

prog="${0##*/}"
rules_file="${YARA_RULES:-/home/rickey/.local/share/yara/linux_persistence_hunt_nightly.yar}"
target="/"
max_size="-5M"
include_all=0
json_output=0
match_count=0
file_count=0
error_count=0

usage() {
    cat <<'HELP'

    Usage:
      scan [OPTIONS] [TARGET]
    
    Options:
      -r, --rules FILE       YARA rules file
      -t, --target PATH      Path to scan
      -a, --all              Broader scan; do not skip large app/cache dirs
      -j, --json             Emit JSON-lines results
      -h, --help             Show help
    
    Environment:
      YARA_RULES             Default rules file override
    
    Examples:
      scan
      scan "$HOME"
      scan /etc
      scan --rules ./linux_persistence_hunt.yar --target "$HOME"

HELP
}

json_escape() {
    jq -Rsr '@json | .[1:-1]'
}

while (($#)); do
    case "$1" in
        -r|--rules)
            [[ $# -ge 2 ]] || { printf '%s: [%s] error missing argument for %s\n' \
                "$(date '+%b %d %T.%3N %Z')" "$prog" "$1" >&2; exit 2; }
            rules_file="$2"; shift 2 ;;
        -t|--target)
            [[ $# -ge 2 ]] || { printf '%s: [%s] error missing argument for %s\n' \
                "$(date '+%b %d %T.%3N %Z')" "$prog" "$1" >&2; exit 2; }
            target="$2"; shift 2 ;;
        -a|--all)
            include_all=1; shift ;;
        -j|--json)
            json_output=1; shift ;;
        -h|--help)
            usage; exit 0 ;;
        --)
            shift; break ;;
        -*)
            printf '%s: [%s] error unknown option: %s\n' \
                "$(date '+%b %d %T.%3N %Z')" "$prog" "$1" >&2; usage >&2; exit 2 ;;
        *)
            target="$1"; shift ;;
    esac
done

if ! command -v yara >/dev/null 2>&1; then
    printf '%s: [%s] error: yara command not found\n' \
        "$(date '+%b %d %T.%3N %Z')" "$prog" >&2
    exit 2
fi

if [[ ! -f "$rules_file" ]]; then
    printf '%s: [%s] error rules file not found: %s\n' \
        "$(date '+%b %d %T.%3N %Z')" "$prog" "$rules_file" >&2
    exit 2
fi

if [[ ! -e "$target" ]]; then
    printf '%s: [%s] error target does not exist: %s\n' \
       "$(date '+%b %d %T.%3N %Z')" "$prog" "$target" >&2
    exit 2
fi

if ! yara -w "$rules_file" /dev/null >/dev/null 2>&1; then
    printf '%s: [%s] error rules file failed to compile: %s\n' \
       "$(date '+%b %d %T.%3N %Z')" "$prog" "$rules_file" >&2
    yara "$rules_file" /dev/null >&2
    exit 2
fi

scan_file() {
    local file=$1 output rc escaped_file escaped_output

    ((file_count++))
    output=$(yara -q -s "$rules_file" "$file" 2>&1)
    rc=$?

    if (( rc != 0 )); then
           ((error_count++))
           if (( json_output == 1 )); then
               escaped_file=$(printf '%s' "$file" | json_escape)
               escaped_output=$(printf '%s' "$output" | json_escape)
               printf '{"date":"%s","program":"%s","file":"%s","result":"error","output":"%s"}\n' \
                   "$(date '+%b %d %T.%3N %Z')" "$prog" "$escaped_file" "$escaped_output"
           else
               printf '%s: [%s] error %s\n%s\n' \
                   "$(date '+%b %d %T.%3N %Z')" "$prog" "$file" "$output" >&2
           fi
           return 0
       fi

       if [[ -n "$output" ]]; then
           ((match_count++))
           if (( json_output == 1 )); then
               escaped_file=$(printf '%s' "$file" | json_escape)
               escaped_output=$(printf '%s' "$output" | json_escape)
               printf '{"date":"%s","program":"%s","file":"%s","result":"match","output":"%s"}\n' \
                   "$(date '+%b %d %T.%3N %Z')" "$prog" "$escaped_file" "$escaped_output"
           else
               printf '%s: [%s] match\n\n%s\n\n' \
                   "$(date '+%b %d %T.%3N %Z')" \
                   "$prog" \
                   "$(printf '%s' "$output" | sed 's/^/\t/')"
           fi
       fi
}

export LC_ALL=C

if (( json_output == 0)); then
    if (( include_all == 0 )); then
        printf '%s: [%s] rules  %s, target directory: %s, mode: default\n' \
            "$(date '+%b %d %T.%3N %Z')" "$prog" "$rules_file" "$target"
    else
        printf '%s: [%s] rules  %s, target directory: %s, mode: broad scan\n' \
            "$(date '+%b %d %T.%3N %Z')" "$prog" "$rules_file" "$target"
    fi
fi

if (( include_all == 0 )); then
    while IFS= read -r -d '' file; do
        scan_file "$file"
    done < <(
        find "$target" \
            -xdev \
            -path /proc -prune -o \
            -path /sys -prune -o \
            -path /dev -prune -o \
            -path /run -prune -o \
            -path /tmp -prune -o \
            -path /var/tmp -prune -o \
            -path /mnt -prune -o \
            -path /media -prune -o \
            -path '*/.cache' -prune -o \
            -path '*/Cache' -prune -o \
            -path '*/.git' -prune -o \
            -path '*/.hg' -prune -o \
            -path '*/.svn' -prune -o \
            -path '*/.venv' -prune -o \
            -path '*/venv' -prune -o \
            -path '*/node_modules' -prune -o \
            -path '*/__pycache__' -prune -o \
            -path '*/.cargo/registry' -prune -o \
            -path '*/.npm' -prune -o \
            -path '*/.local/share/Steam' -prune -o \
            -path '*/.local/share/Trash' -prune -o \
            -path '*/.local/share/nvim/lazy' -prune -o \
            -path '*/.local/share/nvim/mason' -prune -o \
            -path '*/.var/app' -prune -o \
            -path '/var/cache' -prune -o \
            -path '/var/lib/docker' -prune -o \
            -path '/var/lib/containers' -prune -o \
            -path '/var/lib/flatpak' -prune -o \
            -path '/usr/lib' -prune -o \
            -path '/usr/lib64' -prune -o \
            -path '/usr/share' -prune -o \
            -path '/opt' -prune -o \
            -type f \
            -size "$max_size" \
            ! -name "$(basename "$rules_file")" \
            ! -name 'linux_persistence_hunt.yar' \
            ! -name 'linux_persistence_hunt_nightly.yar' \
            -print0 2>/dev/null
    )
else
    while IFS= read -r -d '' file; do
        scan_file "$file"
    done < <(
        find "$target" \
            -xdev \
            -path /proc -prune -o \
            -path /sys -prune -o \
            -path /dev -prune -o \
            -path /run -prune -o \
            -type f \
            -size "$max_size" \
            ! -name "$(basename "$rules_file")" \
            ! -name 'linux_persistence_hunt.yar' \
            ! -name 'linux_persistence_hunt_nightly.yar' \
            -print0 2>/dev/null
    )
fi

if (( json_output == 1 )); then
    printf '{"%s results":{"date":"%s","files scanned":%d,"matches":%d,"errors":%d}}\n' \
        "$prog" "$(date '+%b %d %T.%3N %Z')" "$file_count" "$match_count" "$error_count"
else
    printf '%s: [%s] results files scanned: %d, matches: %d, errors: %d\n' \
        "$(date '+%b %d %T.%3N %Z')" "$prog" "$file_count" "$match_count" "$error_count"
fi

if (( error_count > 0 )); then
    exit 2
elif (( match_count > 0 )); then
    exit 1
else
    exit 0
fi
