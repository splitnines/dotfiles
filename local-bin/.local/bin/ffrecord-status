#!/usr/bin/env bash
set -u

pid_file="${XDG_RUNTIME_DIR:-/tmp}/ffrecord.pid"

recording_pid() {
    local pid

    [[ -f "$pid_file" ]] || return 1

    pid="$(cat "$pid_file" 2>/dev/null || true)"
    [[ -n "$pid" ]] || return 1

    kill -0 "$pid" 2>/dev/null || return 1

    printf '%s\n' "$pid"
}

shown=0

while true; do
    if pid="$(recording_pid)"; then
        shown=1

        elapsed="$(ps -o etimes= -p "$pid" 2>/dev/null | tr -d ' ')"

        if [[ -n "$elapsed" ]]; then
            hours=$((elapsed / 3600))
            minutes=$(((elapsed % 3600) / 60))
            seconds=$((elapsed % 60))

            printf '%02d:%02d:%02d %%{F#ff0000}●%%{F-}\n' \
                "$hours" "$minutes" "$seconds"
        fi

        sleep 1
    else
        rm -f "$pid_file" 2>/dev/null || true

        # Clear the module only once after recording stops.
        if ((shown)); then
            printf '\n'
            shown=0
        fi

        # Idle mode: do not spam blank lines into polybar.
        sleep 2
    fi
done
