#!/usr/bin/env bash

old_stty=$(stty -g)
trap 'stty "$old_stty"; printf "\n"' EXIT

stty -echo -icanon time 0 min 0

elapsed=0
paused=0

while true; do
    key=$(dd bs=1 count=1 2>/dev/null)
   case "$key" in
       p) paused=1;;
       r) paused=0;;
       q) exit 0;;
   esac

    hours=$((elapsed / 3600))
    minutes=$(((elapsed % 3600) / 60))
    seconds=$((elapsed % 60))

    printf '\r\033[K%02d:%02d:%02d%s' \
        "$hours" "$minutes" "$seconds" \
        "$([ "$paused" -eq 1 ] && echo " --paused-- ")"

    if [ "$paused" -eq 0 ]; then
        sleep 1
        ((elapsed++))
    else
        sleep 0.1
    fi

done
