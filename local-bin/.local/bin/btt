#!/usr/bin/env bash
# ~/.local/bin/btt

set -euo pipefail

target_mac="50:5E:5C:07:3C:D3"

require_cmd() {
    local cmd
    for cmd in "$@"; do
        command -v "$cmd" >/dev/null 2>&1 || {
            printf 'error: required command not found: %s\n' "$cmd" >&2
            exit 1
        }
    done
}

bt_cmd() {
    timeout 10s bluetoothctl "$@"
}

main() {
    require_cmd bluetoothctl timeout notify-send
    bt_cmd power on >/dev/null
    sleep 1

    bt_status=$(bt_cmd devices Connected)
    if [ -n "$bt_status" ]; then
        ! bt_cmd disconnect && {
            printf 'error: failed to disconnect from bluetooth devices\n' >&2 &&
            notify-send -t 5000 "Error: Failed to disconnect from bluetooth devices" &&
            exit 1
        }
        notify-send -t 5000 "Disconnected from bluetooth devices"
        exit 0
    fi

    if ! bt_cmd connect "$target_mac"; then
        printf 'error: failed to connect headset %s\n' "$target_mac" >&2
        notify-send "Error: Failed to connect to bluetooth device: $target_mac"
        exit 1
    fi
    notify-send "Connect to bluetooth device: $target_mac"
}

main "$@"
