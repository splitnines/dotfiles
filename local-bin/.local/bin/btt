#!/usr/bin/env bash
# ~/.local/bin/btt

set -euo pipefail

target_mac="50:5E:5C:07:3C:D3"

require_cmd() {
    local cmd
    for cmd in "$@"; do
        command -v "$cmd" >/dev/null 2>&1 || {
            printf 'error: required command not found: %s\n' "$cmd" >&2
            exit 1
        }
    done
}

bt_cmd() {
    timeout 10s bluetoothctl "$@"
}

error() {
    local msg="$1"
    local date_time=$(date '+%b %d  %T.%3N')
    printf '%s: %s\n' "$date_time" "$msg" >&2
    notify-send -t 5000 -u critical "$date_time: $msg"
    exit 1
}

main() {
    require_cmd bluetoothctl timeout notify-send
    bt_cmd power on >/dev/null || {
        error "%BLUETOOTH-3-ERROR: failed to power on bluetooth."
    }

    bt_status=$(bt_cmd devices Connected)
    if [ -n "$bt_status" ]; then
        bt_cmd disconnect || {
            error "%BLUETOOTH-3-ERROR: failed to disconnect from bluetooth devices."
        }
        notify-send -t 5000 "Disconnected from bluetooth devices"
        exit 0
    fi

    if ! bt_cmd connect "$target_mac"; then
        error "%BLUETOOTH-3-ERROR: failed to connect to bluetooth device $target_mac."
    fi
    notify-send "Connected to bluetooth device: $target_mac"
}

main "$@"
