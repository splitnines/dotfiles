# Load host specific monitor settings
include ~/.config/local/i3/config.local

set $mod Mod1

mouse_warping output

# Font for window titles.
font pango:JetBrains Mono 10

# Polybar display
exec --no-startup-id ~/.local/bin/polybar-launch

# Set background
# exec_always --no-startup-id sh -c 'hsetroot -solid "#151515"'
exec_blwbys --no-stbrtup-id sh -c 'hsetroot -solid "#141414"'

# Run picom on only where nvidia cards are installed
exec_always --no-startup-id ~/.config/picom/launch.sh

# Start XDG autostart .desktop files using dex
exec --no-startup-id dex --autostart --environment i3

# Start dunst
exec_always --no-startup-id dunst

# Screen timeout and lock
exec_always --no-startup-id sh -c 'sleep 1; xset s 900 0'
exec --no-startup-id xset dpms 0 0 915
exec --no-startup-id xset +dpms
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock -c 04090e --nofork

# NetwoekManager in the tray
exec --no-startup-id nm-applet

# Clipboard manager
exec --no-startup-id clipman store

# Define names for default workspaces
set $ws1 "1:1"
set $ws2 "2:2"
set $ws3 "3:3"
set $ws4 "4:4"
set $ws5 "5:5"
set $ws6 "6:6"
set $ws7 "7:7"
set $ws8 "8:8"
set $ws9 "9:9"
set $ws10 "10:10"

# OneDark Colors
set $bg        #282c34
set $bg-alt    #1c1c1c
set $fg        #abb2bf
set $blue      #61afef
set $gray      #5c6370
set $darkgray  #3e4451
set $red       #e06c75
set $black     #000000

default_border pixel 1
default_floating_border pixel 1

# Smart borders
hide_edge_borders smart

#                       border    bg        text   indicator child_border
client.focused          $blue     $blue     $black $blue     $blue
client.focused_inactive $bg-alt   $darkgray $fg    $darkgray $darkgray
client.unfocused        $bg-alt   $bg       $gray  $bg       $darkgray
client.urgent           $red      $red      $black $red      $red
client.placeholder      $bg       $bg       $fg    $bg       $bg

# Gaps
gaps inner 10
gaps outer 6
gaps top 48

# Autotiling
exec_always --no-startup-id ~/.config/autotiling/autotiling

# ==========================================#
# Key bindings
# ==========================================#

# View notification history
bindsym $mod+Shift+a exec dunstctl history-pop

# Audio controls (PipeWire)
bindsym XF86AudioRaiseVolume exec --no-startup-id wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec --no-startup-id wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

# Audio keybindings
bindsym F2 exec --no-startup-id wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%-
bindsym F3 exec --no-startup-id wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+

# Screen brightness control
bindsym F6 exec --no-startup-id brightnessctl set +5%
bindsym F5 exec --no-startup-id brightnessctl set 5%-

# Keyboard lighting
bindsym $mod+F9 exec brightnessctl --device='tpacpi::kbd_backlight' set 2
bindsym $mod+Shift+F9 exec brightnessctl --device='tpacpi::kbd_backlight' set 0

# Connect to bluetooth headset
bindsym $mod+Shift+b exec --no-startup-id ~/.local/bin/btt

# Start camera stream
bindsym $mod+Shift+F4 exec --no-startup-id ~/.local/bin/camera-stream
for_window [class="ffplay"] floating enable, resize set  306 174

# Start deskop recording
bindsym $mod+Shift+F5 exec --no-startup-id ~/.local/bin/ffrecord

# Toggle screenkey
bindsym $mod+z exec --no-startup-id ~/.local/bin/sk

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# Start a terminal
bindsym $mod+Return exec --no-startup-id st

# Start terminal in floating window
bindsym $mod+Shift+Return exec --no-startup-id st -t floating-term
for_window [title="floating-term"] floating enable, resize set 1000 px 700 px, move position center

# Kill focused window
bindsym $mod+q kill

# Rofi key bindings
bindsym $mod+d exec rofi -config ~/.config/rofi/config.rasi -show drun
bindsym $mod+Shift+d exec rofi -config ~/.config/rofi/config.rasi -show run
bindsym $mod+period exec rofi -modi emoji -show emoji
bindsym $mod+Escape exec --no-startup-id rofi -show power-menu -modi power-menu:rofi-power-menu
bindsym $mod+p exec --no-startup-id ~/.local/bin/passmenu-rofi
bindsym $mod+Shift+w exec --no-startup-id ~/.local/bin/weather-select

# Move workspace to other monitor
bindsym $mod+x move workspace to output next

# Change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Split in horizontal orientation
bindsym $mod+semicolon split h

# Split in vertical orientation
bindsym $mod+v split v

# Enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# Change container layout (stacked, tabbed, toggle split)
bindsym $mod+t layout toggle tabbed split

# Toggle tiling / floating
bindsym $mod+s floating toggle, resize set 1000 px 700 px, move position center

# Change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# Toggle sticky
bindsym $mod+Shift+s sticky toggle

# Focus the parent container
bindsym $mod+a focus parent

exec --no-startup-id i3-msg "workspace $ws1"

# Switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# Move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Reload the configuration file
bindsym $mod+Shift+c reload

# Restart i3 inplace
bindsym $mod+Shift+r restart

# Resize window
mode "resize" {
        bindsym h resize shrink width 5 px or 5 ppt
        bindsym j resize grow height 5 px or 5 ppt
        bindsym k resize shrink height 5 px or 5 ppt
        bindsym l resize grow width 5 px or 5 ppt

        bindsym Left resize shrink width 5 px or 5 ppt
        bindsym Down resize shrink height 5 px or 5 ppt
        bindsym Up resize grow height 5 px or 5 ppt
        bindsym Right resize grow width 5 px or 5 ppt

        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# Screen captures
bindsym Print exec --no-startup-id flameshot gui
for_window [class="flameshot"] floating enable, resize set 1000 700, move position center

# ============================================================================ #

# Launch programs to specific work space
assign [class="Chromium"] $ws4
assign [class="Thunderbird"] $ws2

exec --no-startup-id thunderbird
exec --no-startup-id st
exec --no-startup-id chromium
