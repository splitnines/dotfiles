alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias atlas='ssh -X rickey@10.0.0.149'
alias atlas-ts='ssh -X rickey@fd7a:115c:a1e0::934:4015'
alias bat='/usr/bin/batcat --style=plain --theme="OneHalfDark" --pager="less -RFX"'
alias bt=bluetoothctl
alias btc='bluetoothctl connect'
alias btd='bluetoothctl disconnect'
alias btl='bluetoothctl devices'
alias cal='ncal -C'
alias egrep='egrep --color=auto'
alias feh='feh --image-bg black'
alias fgrep='fgrep --color=auto'
alias g=git
alias ga='git add .'
alias gb='git branch'
alias gc='git commit'
alias gcm='git commit -m'
alias gco='git checkout'
alias gd='git diff | nvim -'
alias gm='git merge'
alias grep='grep --color=auto'
alias gs='git status'
alias h='fc -li 1'
alias l=ls
alias la='ls -A'
alias le='less -X'
alias ll='ls -Alh'
alias ls='ls --color=auto'
alias md='mkdir -p'
alias nv=/usr/bin/nvim
alias p=/usr/bin/ping
alias path='echo "$PATH" | tr ":" "\n"'
alias pull='git pull'
alias push='git push'
alias python=python3
alias q=exit
alias rcd='/usr/bin/script -m advanced'
alias rs='rsync -avzr'
alias run-help=man
alias t=/usr/bin/telnet
alias ta='/usr/bin/tmux attach -t'
alias tl='/usr/bin/tmux ls'
alias ty='ttyper -w25 -lenglish1000'
